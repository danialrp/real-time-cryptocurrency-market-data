{
  "name": "IRBTC Streamer DevContainer",
  "dockerComposeFile": [
    "../docker-compose.yml",
    "../docker-compose.override.yml"
  ],
  "service": "runtime", 
  "workspaceFolder": "/app", 
  "settings": {
    "go.toolsManagement.autoUpdate": true,
    "go.useLanguageServer": true,
    "go.gopath": "/go", 
    "go.inferGopath": true
  },
  "extensions": [
    "golang.Go"
  ],
  "postCreateCommand": "go mod tidy", 
  "remoteUser": "root" 
}